    {
      "name": "POST/auth",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "let response;\r",
              "let parseError;\r",
              "\r",
              "try {\r",
              "    response = pm.response.json();\r",
              "} catch (e) {\r",
              "    parseError = e.message;\r",
              "}\r",
              "\r",
              "pm.test(\"Method is accepted by endpoint (no 405)\", function () {\r",
              "    pm.expect(pm.response.code).to.not.equal(405,\r",
              "        \"Method Not Allowed — verify method is POST and URL is {{baseUrl}}/auth\");\r",
              "});\r",
              "\r",
              "pm.test(\"Request was not rejected (no 403/401)\", function () {\r",
              "    pm.expect(pm.response.code).to.not.equal(403, \"Forbidden — check credentials\");\r",
              "    pm.expect(pm.response.code).to.not.equal(401, \"Unauthorized\");\r",
              "});\r",
              "\r",
              "pm.test(\"Response is valid JSON (not a plain text error)\", function () {\r",
              "    pm.expect(parseError, `JSON parse failed: ${parseError}`).to.be.undefined;\r",
              "    pm.expect(response).to.not.be.undefined;\r",
              "});\r",
              "\r",
              "if (response) {\r",
              "pm.environment.set(\"authToken\", response.token);\r",
              "\r",
              "pm.test(\"Status code is 200\", function () {\r",
              "    pm.response.to.have.status(200);\r",
              "});\r",
              "\r",
              "pm.test(\"Token is present in the response\", function () {\r",
              "    pm.expect(pm.response.json().token).to.not.be.undefined;\r",
              "    });\r",
              "\r",
              "pm.test(\"Token contains only alphanumeric characters\", function () {\r",
              "    pm.expect(response.token).to.match(/^[a-zA-Z0-9]+$/);\r",
              "});\r",
              "\r",
              "pm.test(\"Token is not empty and is saved to environment\", () => {\r",
              "    pm.expect(response.token).to.not.be.empty;\r",
              "    pm.expect(pm.environment.get(\"authToken\")).to.equal(response.token);\r",
              "});\r",
              "\r",
              "pm.test(\"Response time is less than 2000ms\", function () {\r",
              "    pm.expect(pm.response.responseTime).to.be.below(2000);\r",
              "    });\r",
              "\r",
              "pm.test(\"Response does not expose password or credentials\", function () {\r",
              "    const body = pm.response.text();\r",
              "    pm.expect(body).to.not.include(\"password123\");\r",
              "    pm.expect(body).to.not.include(\"admin\");\r",
              "});\r",
              "\r",
              "}"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
