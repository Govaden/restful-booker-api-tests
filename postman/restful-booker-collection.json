              "    pm.expect(response.length).to.be.above(0);\r",
              "});\r",
              "\r",
              "pm.test(\"Every item in the array has a numeric bookingid\", function () {\r",
              "    response.forEach((item, index) => {\r",
              "        pm.expect(item, `Item at index ${index}`).to.have.property(\"bookingid\");\r",
              "        pm.expect(item.bookingid, `bookingid at index ${index}`).to.be.a(\"number\");\r",
              "    });\r",
              "});\r",
              "\r",
              "pm.test(\"Created booking ID exists in the listing\", function () {\r",
              "    const savedId = parseInt(pm.environment.get(\"bookingId\"));\r",
              "    const ids = response.map(item => item.bookingid);\r",
              "    pm.expect(ids).to.include(savedId);\r",
              "});\r",
              "\r",
              "pm.test(\"No duplicate booking IDs in the list\", function () {\r",
              "    const ids = response.map(item => item.bookingid);\r",
              "    const unique = [...new Set(ids)];\r",
              "    pm.expect(ids.length).to.equal(unique.length);\r",
              "});\r",
              "\r",
              "pm.test(\"Response time is under 2000ms\", function () {\r",
