      "name": "PATCH/booking",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "const response = pm.response.json();\r",
              "\r",
              "pm.test(\"Status code is 200\", function () {\r",
              "    pm.response.to.have.status(200);\r",
              "});\r",
              "\r",
              "pm.test(\"Patched fields reflect the new values\", function () {\r",
              "    pm.expect(response.firstname).to.equal(\"Jane\");\r",
              "    pm.expect(response.totalprice).to.equal(750);\r",
              "});\r",
              "\r",
              "pm.test(\"Unpatched fields retain their previous values from PUT\", function () {\r",
              "    pm.expect(response.lastname).to.equal(\"Smith\");\r",
              "    pm.expect(response.depositpaid).to.equal(false);\r",
              "    pm.expect(response.additionalneeds).to.equal(\"Lunch\");\r",
              "});\r",
              "\r",
              "pm.test(\"Response still contains all required booking fields\", function () {\r",
              "    [\"firstname\", \"lastname\", \"totalprice\", \"depositpaid\", \"bookingdates\"].forEach(field => {\r",
              "        pm.expect(response).to.have.property(field);\r",
              "    });\r",
              "});\r",
              "\r",
              "pm.test(\"Patched field types are correct\", function () {\r",
              "    pm.expect(response.firstname).to.be.a(\"string\").and.not.be.empty;\r",
